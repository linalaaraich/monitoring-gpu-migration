# =============================================================================
# .env — secrets + environment values consumed by docker-compose.yml.
#
# DO NOT COMMIT THIS FILE TO GIT. Place it on the GPU box at
#   /opt/cires-ai/.env
# owned by root:root with mode 0600. The Ansible role renders it from a
# group_vars (vault-encrypted) template on each playbook run, overwriting
# any manual edits — source of truth is ansible, not this box.
#
# File is read via `env_file:` in the compose file. All variables below
# are referenced by docker-compose.yml; missing ones will cause
# `docker compose up` to fail with a clear "variable X is required" error
# (we used `${X:?}` interpolation for the critical ones).
# =============================================================================

# --- Image tag -----------------------------------------------------------
# Tag for cires/triage-service and cires/mcp-*. Built by the Ansible role.
# Date-based to stay consistent with the k3s-era convention.
IMAGE_TAG=2026-04-23

# --- Model ---------------------------------------------------------------
# Ollama model tag. `qwen2.5:14b` → 14b-instruct-q4_K_M (~9 GB VRAM).
# To A/B against another model, change here and redeploy — ollama-init
# will idempotently pull the new one; the old one stays on disk until
# you `docker exec ollama ollama rm <tag>`.
OLLAMA_MODEL=qwen2.5:14b

# --- Monitoring VM -------------------------------------------------------
# Private IP of the monitoring VM in the same VPC (10.0.0.0/16). Used by
# triage for direct Loki seeding, by the MCPs for upstream queries, and
# by the email-escalation code to build clickable Grafana dashboard URLs.
#
# Safe to set to the monitoring EIP (52.202.21.192) instead — VPC-internal
# routing still applies, SG-monitoring accepts the traffic because the
# source IP is the GPU box's private IP.
MONITORING_VM_IP=52.202.21.192

# --- SMTP (Gmail App Password) -------------------------------------------
# Used by triage to email escalations. Reuse the creds from the current
# monitoring-project group_vars — do NOT check fresh credentials in here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME@gmail.com
SMTP_PASSWORD=REPLACE_ME_APP_PASSWORD
SMTP_FROM=REPLACE_ME@gmail.com
NOTIFICATION_EMAIL=REPLACE_ME@gmail.com
