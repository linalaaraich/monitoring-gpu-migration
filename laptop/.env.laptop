# =============================================================================
# .env for the laptop integration test.
# Save as `.env` next to docker-compose.yml (drop the .laptop suffix).
# On WSL2 the path is typically ~/cires-ai/.env
#
# Differences vs. the cloud A10 .env.example:
#   - OLLAMA_MODEL → qwen2.5:7b (fits in GTX 1060's 6 GB VRAM)
#   - MONITORING_VM_IP → the monitoring VM's TAILSCALE IP (not its EIP)
#     Find it with: `tailscale status` on any peer, look for the row
#     tagged "observability-rca-monitoring".
#   - Mode 0600 less enforceable on NTFS than on ext4; if you care, put
#     this file on the WSL2 ext4 filesystem (/home/<you>/cires-ai/),
#     not a mounted /mnt/c/ path.
# =============================================================================

IMAGE_TAG=laptop-dev

# qwen2.5:7b = qwen2.5:7b-instruct-q4_K_M by Ollama's default tag.
# Footprint: ~5 GB VRAM (model) + ~1 GB KV cache. Fits 6 GB with room.
OLLAMA_MODEL=qwen2.5:7b

# SET AFTER `tailscale status` shows the monitoring VM's 100.x.x.x address.
# Leave placeholder until then — docker compose will fail loud with
# "MONITORING_VM_IP must be set" rather than start with a dud value.
MONITORING_VM_IP=REPLACE_WITH_MONITORING_TAILSCALE_IP

# SMTP — reuse the existing Gmail app password from the monitoring-project
# ansible vault. Triage only uses SMTP for the escalate email; if you
# don't care about escalation emails during the smoke test, leave these
# as dummy values — email send will fail with a clear log line and the
# pipeline will still produce a decision.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME@gmail.com
SMTP_PASSWORD=REPLACE_ME_APP_PASSWORD
SMTP_FROM=REPLACE_ME@gmail.com
NOTIFICATION_EMAIL=REPLACE_ME@gmail.com
